\contentsline {figure}{\numberline {8.4}{\ignorespaces Admin Dashboard showing summary cards (total students, doctors, pending approvals), academic year management, and quick access to user management and system configuration.}}{80}{figure.8.4}%
\contentsline {figure}{\numberline {8.6}{\ignorespaces Doctor Bulk Attendance Recording interface showing date picker, student list with Present/Absent options.}}{80}{figure.8.6}%

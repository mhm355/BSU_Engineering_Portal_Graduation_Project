{
  "dashboard": {
    "id": null,
    "title": "BSU Portal - Database Health",
    "tags": ["bsu", "database", "mysql"],
    "timezone": "browser",
    "schemaVersion": 36,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "MySQL Status",
        "type": "stat",
        "targets": [
          {
            "expr": "mysql_up",
            "legendFormat": "MySQL"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"options": {"0": {"text": "DOWN", "color": "red"}}, "type": "value"},
              {"options": {"1": {"text": "UP", "color": "green"}}, "type": "value"}
            ]
          }
        },
        "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Active Connections",
        "type": "stat",
        "targets": [
          {
            "expr": "mysql_global_status_threads_connected",
            "legendFormat": "Connections"
          }
        ],
        "gridPos": {"h": 4, "w": 5, "x": 4, "y": 0}
      },
      {
        "id": 3,
        "title": "Connection Usage %",
        "type": "stat",
        "targets": [
          {
            "expr": "(mysql_global_status_threads_connected / mysql_global_variables_max_connections) * 100",
            "legendFormat": "Usage %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 70},
                {"color": "red", "value": 90}
              ]
            }
          }
        },
        "gridPos": {"h": 4, "w": 5, "x": 9, "y": 0}
      },
      {
        "id": 4,
        "title": "Slow Queries",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(mysql_global_status_slow_queries[5m])",
            "legendFormat": "Slow Queries/sec"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 1},
                {"color": "red", "value": 5}
              ]
            }
          }
        },
        "gridPos": {"h": 4, "w": 5, "x": 14, "y": 0}
      },
      {
        "id": 5,
        "title": "Queries Per Second",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(mysql_global_status_queries[1m])",
            "legendFormat": "QPS"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4}
      },
      {
        "id": 6,
        "title": "InnoDB Buffer Pool Usage",
        "type": "timeseries",
        "targets": [
          {
            "expr": "mysql_global_status_innodb_buffer_pool_pages_total",
            "legendFormat": "Total Pages"
          },
          {
            "expr": "mysql_global_status_innodb_buffer_pool_pages_free",
            "legendFormat": "Free Pages"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4}
      }
    ]
  }
}

{
  "id": null,
  "uid": "bsu-prometheus-targets",
  "title": "BSU Portal - Prometheus Targets",
  "tags": ["bsu", "prometheus", "targets"],
  "timezone": "browser",
  "schemaVersion": 36,
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "title": "Target Status Overview",
      "type": "stat",
      "description": "Shows UP/DOWN status for each Prometheus scrape target",
      "targets": [
        {
          "expr": "up",
          "legendFormat": "{{job}} ({{instance}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"options": {"0": {"text": "DOWN", "color": "red"}}, "type": "value"},
            {"options": {"1": {"text": "UP", "color": "green"}}, "type": "value"}
          ]
        }
      },
      "gridPos": {"h": 6, "w": 24, "x": 0, "y": 0}
    },
    {
      "id": 2,
      "title": "Targets UP Count",
      "type": "stat",
      "targets": [
        {
          "expr": "count(up == 1)",
          "legendFormat": "Targets UP",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "green"},
          "thresholds": {
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 6}
    },
    {
      "id": 3,
      "title": "Targets DOWN Count",
      "type": "stat",
      "targets": [
        {
          "expr": "count(up == 0)",
          "legendFormat": "Targets DOWN",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "red"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 6}
    },
    {
      "id": 4,
      "title": "Scrape Duration (seconds)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "scrape_duration_seconds",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10}
    },
    {
      "id": 5,
      "title": "Scrape Samples Scraped",
      "type": "timeseries",
      "targets": [
        {
          "expr": "scrape_samples_scraped",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10}
    },
    {
      "id": 6,
      "title": "Target Status History",
      "type": "timeseries",
      "description": "Shows the up/down history of all targets over time",
      "targets": [
        {
          "expr": "up",
          "legendFormat": "{{job}} ({{instance}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "mappings": [
            {"options": {"0": {"text": "DOWN"}}, "type": "value"},
            {"options": {"1": {"text": "UP"}}, "type": "value"}
          ]
        }
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 18}
    }
  ]
}
